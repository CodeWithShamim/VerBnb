VerBnb - backend (contracts, tests, deploy) environment
# Copy this file to .env and fill in your values. NEVER commit a real key.

GENLAYER_PRIVATE_KEY=
GENLAYER_NETWORK=testnet_bradbury

# Contract addresses live in deployments/bradbury.json (written by the deploy
# script); the frontend reads them from there, not from env.
NEXT_PUBLIC_GL_NETWORK=testnet_bradbury
NEXT_PUBLIC_GL_RPC=https://rpc-bradbury.genlayer.com

# Server-only (NEVER prefixed with NEXT_PUBLIC_ - used only in API routes):
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud