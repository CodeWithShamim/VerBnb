# VerBnb frontend env. Copy to .env.local and fill in.
# Public (safe to expose to the browser):
NEXT_PUBLIC_VERBNB_REGISTRY=0x8aA6527B539814c454ee178dd7CE8cAd011834eB
NEXT_PUBLIC_GL_NETWORK=testnet_bradbury
NEXT_PUBLIC_GL_RPC=https://rpc-bradbury.genlayer.com
# Block explorer base URL (used for "View on explorer" links). Defaults to the
# Bradbury explorer when unset.
NEXT_PUBLIC_GL_EXPLORER=https://explorer-bradbury.genlayer.com

# Wallet connection (Privy). Create a free app at https://dashboard.privy.io
# and paste its App ID here. When set, users connect & sign disputes with their
# OWN wallet. When empty, the app falls back to the server-side signer below.
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-only (NEVER prefixed with NEXT_PUBLIC_ — used only in API routes):
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=gateway.pinata.cloud
GENLAYER_PRIVATE_KEY=0xyour_funded_bradbury_key

