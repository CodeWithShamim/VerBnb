# VerBnb frontend env. Copy to .env.local and fill in.
# Contract addresses are NOT set here - the frontend reads all of them from
# deployments/<network>.json (written by `python tools/deploy.py`).
# Public (safe to expose to the browser):
NEXT_PUBLIC_GL_NETWORK=studionet
NEXT_PUBLIC_GL_RPC=https://studio.genlayer.com/api
# Optional block explorer base URL override (used for "View on explorer"
# links). Studionet has no public explorer, so explorer links are hidden there
# unless this is set.
#NEXT_PUBLIC_GL_EXPLORER=

# Wallet connection (Privy). Create a free app at https://dashboard.privy.io
# and paste its App ID here. When set, users connect & sign disputes with their
# OWN wallet. When empty, the app falls back to the server-side signer below.
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-only (NEVER prefixed with NEXT_PUBLIC_ - used only in API routes):
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=gateway.pinata.cloud
GENLAYER_PRIVATE_KEY=0xyour_funded_network_key

